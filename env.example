# Caption server settings
APP_NAME=Church Cap
APP_VERSION=0.7.1
# APP_VERSION is kept for old scripts; the displayed app version is code-owned to avoid stale .env values.
FEEDBACK_EMAIL=info@churchcap.org
HOST=0.0.0.0
PORT=8080
VIEWER_PORT=8080
OPERATOR_PORT=9090
DUAL_PORT_MODE=false
LOCK_OPERATOR_TO_LOCALHOST=true
# Optional override. Leave blank to auto-use the Mac Bonjour hostname, e.g. http://church-cap.local:8080.
# Set this manually only if you use router DNS, a fixed domain, or a custom HTTPS URL.
PUBLIC_BASE_URL=

# Operator security - CHANGE THESE BEFORE CHURCH USE
OPERATOR_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string
SESSION_MAX_AGE_SECONDS=28800

# Transcription defaults. The operator page Performance controls can override
# these values at runtime; saved operator choices live in the per-user
# runtime_config.json file and apply when captions next start.
TRANSCRIBER_MODE=whisper
WHISPER_MODEL=base.en
# Use auto unless you need to force a runtime. The default standard Whisper
# backend favours accuracy/consistency over speed. Set TRANSCRIBER_MODE=faster_whisper
# to use the faster CTranslate2 backend instead.
# On Windows, faster_whisper auto uses CUDA + float16 only when CTranslate2 can
# see an NVIDIA GPU and the required CUDA runtime DLLs, such as cublas64_12.dll
# and cuDNN DLLs, are available. Otherwise, auto falls back to CPU + int8.
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BEAM_SIZE=5
LANGUAGE=en
# Low-cost accuracy hint for Whisper. Add local church names, Bible books,
# sermon series titles, or recurring terms here rather than increasing model size.
WHISPER_INITIAL_PROMPT=Church service audio with prayer, Bible readings, worship, sermon, Scripture, Jesus Christ, Holy Spirit, Psalm, Psalms, Ephesians, Corinthians, Thessalonians.

# Audio settings
AUDIO_DEVICE=
SAMPLE_RATE=16000
CHUNK_SECONDS=2

# UI/message settings
CHURCH_NAME=Church Cap
DND_REMINDER=true

# Privacy defaults; can also be changed on /operator
TRANSCRIPT_SAVING_ENABLED=true
TRANSCRIPT_RETENTION_MINUTES=120

# Rolling transcription defaults. These can also be tuned from the operator page.
STREAM_WINDOW_SECONDS=8
STREAM_UPDATE_INTERVAL_SECONDS=1.2
STREAM_SILENCE_FINALISE_SECONDS=1.45
STREAM_MIN_RMS=0.006
STREAM_STABILITY_PASSES=2
STREAM_WORD_TIMESTAMPS_ENABLED=true
STREAM_EDGE_GUARD_SECONDS=0.32
STREAM_EDGE_CONFIDENCE_THRESHOLD=0.65
STREAM_COMMITTED_AUDIO_OVERLAP_SECONDS=1.0

# OPERATOR_PASSWORD is optional. If left as change-me or omitted,
# the app will prompt the operator to create a password at first startup.
# Session secrets are generated locally and persist across restarts for reliable Sunday-morning re-login.
# They rotate when the operator password is changed.

# Optional translation support. UI language selection is local and lightweight:
# visitor page labels use app/locales/client_ui.json and fall back to English.
# Caption translation is experimental and disabled by default because every active
# translated language increases CPU/RAM use and translations may be inaccurate.
# Argos runs locally after dependencies and language packages are installed with:
#   ./scripts/install-translation-models-argos.sh --enable
# Windows:
#   powershell -ExecutionPolicy Bypass -File .\scripts\install-translation-models-argos.ps1 -Enable
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=argos
# Efficient neural translation path: ct2small100 uses a converted CTranslate2 INT8 SMaLL-100 model when installed.
TRANSLATION_ALLOWED_LANGUAGES=en
TRANSLATION_MAX_ACTIVE_LANGUAGES=2
# The operator Languages page can lower this for weaker systems or raise it up
# to the full supported language catalogue on powerful hardware.
# To test language routing without real translation, set TRANSLATION_PROVIDER=demo.
# Demo mode only prefixes captions and must not be used as real translation.


# Optional explicit deployment identity. Leave unset for normal desktop installs.
# Appliance installers set these or create /etc/churchcap-appliance/identity.json.
# appliance_cpu keeps an English-first appliance UI, but Languages remains
# available as an advanced warned option capped at three active translations.
# appliance_gpu ties translated-caption use to CUDA readiness.
# CHURCHCAP_DEPLOYMENT=appliance
# CHURCHCAP_PROFILE=appliance_cpu
# CHURCHCAP_APPLIANCE_ID=box-example
